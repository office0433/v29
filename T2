WITH app_objects AS (
    SELECT 'PSG' AS SCHEMA_NAME, 'VW_NEW_INGESTION_STATUS_LAST_14_DAYS' AS OBJECT_NAME UNION ALL
    SELECT 'PSG', 'VW_CORE_INGESTION_SF_LOAD_STATUS' UNION ALL
    SELECT 'PMD', 'INSIGHTS_CORE_INGESTION' UNION ALL
    SELECT 'BACKUP_OPS', 'TABLE_COMMENTS' UNION ALL
    SELECT 'PSG', 'OPS_TEAM_STATIC_INTERFACE_TABLE'
)
SELECT
    'DB_CORE_PRD.' || o.SCHEMA_NAME || '.' || o.OBJECT_NAME AS FULL_OBJECT_NAME,
    t.TABLE_TYPE,
    t.CREATED,
    t.LAST_ALTERED
FROM app_objects o
LEFT JOIN DB_CORE_PRD.INFORMATION_SCHEMA.TABLES t
    ON t.TABLE_SCHEMA = o.SCHEMA_NAME
   AND t.TABLE_NAME = o.OBJECT_NAME
ORDER BY FULL_OBJECT_NAME;

SELECT GET_DDL('VIEW', 'DB_CORE_PRD.PSG.VW_NEW_INGESTION_STATUS_LAST_14_DAYS') AS DDL;

SELECT GET_DDL('VIEW', 'DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS') AS DDL;

SELECT GET_DDL('TABLE', 'DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION') AS DDL;

SELECT GET_DDL('TABLE', 'DB_CORE_PRD.BACKUP_OPS.TABLE_COMMENTS') AS DDL;

SELECT GET_DDL('TABLE', 'DB_CORE_PRD.PSG.OPS_TEAM_STATIC_INTERFACE_TABLE') AS DDL;
