SELECT
    PSG_TABLE_NAME,
    COUNT(*) AS DUPLICATE_COUNT,
    MIN(AUDIT_START_DATE) AS FIRST_ADDED_DATE,
    MAX(AUDIT_START_DATE) AS LAST_ADDED_DATE,
    MIN(AUDIT_FILE_PROCESSED_DATE) AS FIRST_FILE_PROCESSED_DATE,
    MAX(AUDIT_FILE_PROCESSED_DATE) AS LAST_FILE_PROCESSED_DATE
FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION
WHERE AUDIT_CURRENT = TRUE
GROUP BY PSG_TABLE_NAME
HAVING COUNT(*) > 1
ORDER BY DUPLICATE_COUNT DESC, PSG_TABLE_NAME;
