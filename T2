WITH APP_TABLES AS (
    SELECT DISTINCT UPPER(TRIM(TABLE_NAME)) AS TABLE_KEY
    FROM DB_CORE_PRD.PSG.VW_NEW_INGESTION_STATUS_LAST_14_DAYS
),

PMD_LOOKUP AS (
    SELECT
        UPPER(TRIM(PSG_TABLE_NAME)) AS PSG_KEY,
        UPPER(TRIM(INTERFACE_NAME)) AS INTERFACE_KEY,
        PSG_TABLE_NAME,
        INTERFACE_NAME,
        PROJECT,
        SOURCE_SYSTEM,
        AUDIT_FILE_NAME,
        AUDIT_CURRENT
    FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION
    WHERE AUDIT_CURRENT = TRUE
      AND AUDIT_FILE_NAME = 'STREAMLIT_APP'
)

SELECT
    A.TABLE_KEY,
    P.PSG_TABLE_NAME,
    P.INTERFACE_NAME,
    P.PROJECT,
    P.SOURCE_SYSTEM,
    P.AUDIT_FILE_NAME
FROM APP_TABLES A
LEFT JOIN PMD_LOOKUP P
    ON A.TABLE_KEY = P.PSG_KEY
    OR A.TABLE_KEY = P.INTERFACE_KEY
WHERE P.PSG_TABLE_NAME IS NULL
ORDER BY A.TABLE_KEY;
