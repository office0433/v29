WITH expected AS (
    SELECT column1 AS TABLE_NAME
    FROM VALUES
        ('ASSET_PRODUCT_TYPE'),
        ('MEDIA_METRICS'),
        ('ORDERS'),
        ('ORDER_PAYMENT_ACTION_TYPES')
)

SELECT
    e.TABLE_NAME AS EXPECTED_TABLE,
    l.PIPELINE,
    l.AUDIT_JOB_GUID,
    MIN(l.STARTED_AT) AS MIN_STARTED_AT,
    MAX(l.STARTED_AT) AS MAX_STARTED_AT,
    LISTAGG(DISTINCT l.LOG_LEVEL_NAME, ', ')
        WITHIN GROUP (ORDER BY l.LOG_LEVEL_NAME) AS LOG_LEVELS,
    COUNT(*) AS RAW_LOG_ROWS
FROM expected e
LEFT JOIN DB_CORE_PRD.PMD.AUDIT_INGESTION_LOG l
    ON UPPER(l.PIPELINE) LIKE '%' || UPPER(e.TABLE_NAME) || '%'
   AND DATE_TRUNC('DAY', l.STARTED_AT) > CURRENT_DATE - 60
   AND l.PIPELINE <> 'None'
GROUP BY
    e.TABLE_NAME,
    l.PIPELINE,
    l.AUDIT_JOB_GUID
ORDER BY
    e.TABLE_NAME,
    MAX_STARTED_AT DESC;
