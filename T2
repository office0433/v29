WITH PMD_TABLES AS (
    SELECT
        UPPER(TRIM(PSG_TABLE_NAME)) AS DISPLAY_TABLE_NAME,
        UPPER(TRIM(INTERFACE_NAME)) AS INTERFACE_NAME,
        AUDIT_START_DATE
    FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION
    WHERE AUDIT_CURRENT = TRUE
      AND PSG_TABLE_NAME IS NOT NULL
      AND TRIM(PSG_TABLE_NAME) <> ''
),

AUDIT_NAMES AS (
    SELECT DISTINCT UPPER(TRIM(TABLE_NAME)) AS AUDIT_TABLE_NAME
    FROM DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS
),

NEW_TABLES AS (
    SELECT
        P.DISPLAY_TABLE_NAME AS TABLE_NAME,
        COALESCE(A1.AUDIT_TABLE_NAME, A2.AUDIT_TABLE_NAME, P.DISPLAY_TABLE_NAME) AS AUDIT_TABLE_NAME
    FROM PMD_TABLES P
    LEFT JOIN AUDIT_NAMES A1
        ON A1.AUDIT_TABLE_NAME = P.DISPLAY_TABLE_NAME
    LEFT JOIN AUDIT_NAMES A2
        ON A2.AUDIT_TABLE_NAME = P.INTERFACE_NAME
    WHERE NOT EXISTS (
        SELECT 1
        FROM DB_CORE_PRD.PSG.OPS_TEAM_STATIC_INTERFACE_TABLE SIT
        WHERE UPPER(TRIM(SIT.TABLE_NAME)) = P.DISPLAY_TABLE_NAME
    )
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY P.DISPLAY_TABLE_NAME
        ORDER BY
            CASE WHEN A1.AUDIT_TABLE_NAME IS NOT NULL THEN 1
                 WHEN A2.AUDIT_TABLE_NAME IS NOT NULL THEN 2
                 ELSE 3
            END,
            P.AUDIT_START_DATE DESC
    ) = 1
),

LAST_14_DAYS AS (
    SELECT DAY_DT
    FROM DB_CORE_PRD.PSG.TIME_DAY_DM
    WHERE DAY_DT BETWEEN DATEADD(DAY, -13, CURRENT_DATE()) AND CURRENT_DATE()
),

FIRST_RUN AS (
    SELECT
        UPPER(TRIM(TABLE_NAME)) AS AUDIT_TABLE_NAME,
        MIN(CAST(START_DT AS DATE)) AS FIRST_RUN_DATE
    FROM DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS
    WHERE PROCESS_STATUS = 'COMPLETE'
    GROUP BY UPPER(TRIM(TABLE_NAME))
),

LATEST_RUN_PER_DAY AS (
    SELECT
        UPPER(TRIM(TABLE_NAME)) AS AUDIT_TABLE_NAME,
        CAST(DATE_TRUNC('DAY', START_DT) AS DATE) AS RUN_DATE,
        PROCESS_STATUS,
        ROW_NUMBER() OVER (
            PARTITION BY UPPER(TRIM(TABLE_NAME)), CAST(DATE_TRUNC('DAY', START_DT) AS DATE)
            ORDER BY START_DT DESC
        ) AS RN
    FROM DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS
    WHERE CAST(START_DT AS DATE) BETWEEN DATEADD(DAY, -13, CURRENT_DATE()) AND CURRENT_DATE()
)

SELECT
    NT.TABLE_NAME,
    FR.FIRST_RUN_DATE,
    D.DAY_DT AS RUN_DATE,
    CASE
        WHEN LR.PROCESS_STATUS = 'COMPLETE' THEN 'Green'
        WHEN LR.PROCESS_STATUS = 'ERROR' THEN 'Red'
        ELSE 'Yellow'
    END AS RUN_STATUS
FROM NEW_TABLES NT
CROSS JOIN LAST_14_DAYS D
LEFT JOIN LATEST_RUN_PER_DAY LR
    ON LR.AUDIT_TABLE_NAME = NT.AUDIT_TABLE_NAME
   AND LR.RUN_DATE = D.DAY_DT
   AND LR.RN = 1
LEFT JOIN FIRST_RUN FR
    ON FR.AUDIT_TABLE_NAME = NT.AUDIT_TABLE_NAME
ORDER BY NT.TABLE_NAME, D.DAY_DT;
