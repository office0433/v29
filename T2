WITH NEW_TABLES AS (
    SELECT DISTINCT M.PSG_TABLE_NAME AS TABLE_NAME
    FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION M
    WHERE NOT EXISTS (
        SELECT 1
        FROM DB_CORE_PRD.PSG.OPS_TEAM_STATIC_INTERFACE_TABLE SIT
        WHERE SIT.TABLE_NAME = M.PSG_TABLE_NAME
    )
)

SELECT COUNT(DISTINCT TABLE_NAME) AS NEW_TABLE_COUNT
FROM NEW_TABLES;



WITH NEW_TABLES AS (
    SELECT DISTINCT M.PSG_TABLE_NAME AS TABLE_NAME
    FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION M
