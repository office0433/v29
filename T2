SELECT
    PSG_TABLE_NAME,
    INTERFACE_NAME,
    SOURCE_SYSTEM,
    PROJECT,
    DATABASE_NAME,
    STAGE_TABLE_NAME,
    AUDIT_START_DATE,
    AUDIT_FILE_NAME
FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION
WHERE AUDIT_CURRENT = TRUE
  AND PSG_TABLE_NAME IN (
      'ASSET_PRODUCT_TYPE',
      'ORDER_PAYMENT_ACTION_TYPES',
      'ORDERS',
      'PRODUCT_AVAILABILITY_HOURLY_SNAPSHOT'
  )
ORDER BY PSG_TABLE_NAME, AUDIT_START_DATE DESC;



SELECT DISTINCT
    PIPELINE,
    TABLE_NAME,
    INTERFACE_SOURCE
FROM DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS
WHERE UPPER(PIPELINE) LIKE '%ASSET_PRODUCT_TYPE%'
   OR UPPER(PIPELINE) LIKE '%ORDER_PAYMENT_ACTION_TYPES%'
   OR UPPER(PIPELINE) LIKE '%ORDERS%'
   OR UPPER(PIPELINE) LIKE '%PRODUCT_AVAILABILITY_HOURLY_SNAPSHOT%'
   OR UPPER(TABLE_NAME) LIKE '%ASSET_PRODUCT_TYPE%'
   OR UPPER(TABLE_NAME) LIKE '%ORDER_PAYMENT_ACTION_TYPES%'
   OR UPPER(TABLE_NAME) LIKE '%ORDERS%'
   OR UPPER(TABLE_NAME) LIKE '%PRODUCT_AVAILABILITY_HOURLY_SNAPSHOT%'
ORDER BY TABLE_NAME;
