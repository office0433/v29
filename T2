WITH NEW_TABLES AS (
    SELECT
        M.PSG_TABLE_NAME AS TABLE_NAME,
        COALESCE(V1.TABLE_NAME, V2.TABLE_NAME) AS AUDIT_TABLE_NAME
    FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION M
    LEFT JOIN (
        SELECT DISTINCT TABLE_NAME
        FROM DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS
    ) V1
        ON UPPER(TRIM(V1.TABLE_NAME)) = UPPER(TRIM(M.PSG_TABLE_NAME))
    LEFT JOIN (
        SELECT DISTINCT TABLE_NAME
        FROM DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS
    ) V2
        ON UPPER(TRIM(V2.TABLE_NAME)) = UPPER(TRIM(M.INTERFACE_NAME))
    WHERE M.AUDIT_CURRENT = TRUE
      AND NOT EXISTS (
          SELECT 1
          FROM DB_CORE_PRD.PSG.OPS_TEAM_STATIC_INTERFACE_TABLE SIT
          WHERE UPPER(TRIM(SIT.TABLE_NAME)) = UPPER(TRIM(M.PSG_TABLE_NAME))
      )
)

SELECT
    TABLE_NAME,
    AUDIT_TABLE_NAME
FROM NEW_TABLES
WHERE TABLE_NAME IN (
    'ASSET_PRODUCT_TYPE',
    'MEDIA_METRICS',
    'ORDERS',
    'ORDER_PAYMENT_ACTION_TYPES'
)
ORDER BY TABLE_NAME;
