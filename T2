WITH expected AS (
    SELECT UPPER(TRIM(column1)) AS TABLE_KEY
    FROM VALUES
        ('MISSING_TABLE_1'),
        ('MISSING_TABLE_2')
),

metadata AS (
    SELECT
        UPPER(TRIM(PSG_TABLE_NAME)) AS TABLE_KEY,
        PSG_TABLE_NAME,
        INTERFACE_NAME,
        PROJECT,
        SOURCE_SYSTEM,
        AUDIT_CURRENT
    FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION
    WHERE AUDIT_CURRENT = TRUE
),

audit_view AS (
    SELECT
        UPPER(TRIM(TABLE_NAME)) AS TABLE_KEY,
        TABLE_NAME,
        COUNT(*) AS AUDIT_VIEW_ROWS,
        MIN(START_DT) AS MIN_START_DT,
        MAX(START_DT) AS MAX_START_DT,
        LISTAGG(DISTINCT PROCESS_STATUS, ', ')
            WITHIN GROUP (ORDER BY PROCESS_STATUS) AS STATUSES
    FROM DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS
    GROUP BY 1, 2
),

static_table AS (
    SELECT
        UPPER(TRIM(TABLE_NAME)) AS TABLE_KEY,
        TABLE_NAME,
        COUNT(*) AS STATIC_ROWS,
        MAX(APPROVED_AT) AS LAST_APPROVED_AT,
        LISTAGG(DISTINCT STATUS, ', ')
            WITHIN GROUP (ORDER BY STATUS) AS STATIC_STATUSES
    FROM DB_CORE_PRD.PSG.OPS_TEAM_STATIC_INTERFACE_TABLE
    GROUP BY 1, 2
),

home_view AS (
    SELECT
        UPPER(TRIM(TABLE_NAME)) AS TABLE_KEY,
        TABLE_NAME,
        COUNT(*) AS HOME_VIEW_ROWS,
        MIN(FIRST_RUN_DATE) AS FIRST_RUN_DATE,
        MIN(RUN_DATE) AS MIN_RUN_DATE,
        MAX(RUN_DATE) AS MAX_RUN_DATE,
        LISTAGG(DISTINCT RUN_STATUS, ', ')
            WITHIN GROUP (ORDER BY RUN_STATUS) AS HOME_STATUSES
    FROM DB_CORE_PRD.PSG.VW_NEW_INGESTION_STATUS_LAST_14_DAYS
    GROUP BY 1, 2
)

SELECT
    e.TABLE_KEY AS EXPECTED_TABLE,
    m.PSG_TABLE_NAME,
    m.INTERFACE_NAME,
    m.PROJECT,
    m.SOURCE_SYSTEM,
    m.AUDIT_CURRENT,

    COALESCE(a.AUDIT_VIEW_ROWS, 0) AS AUDIT_VIEW_ROWS,
    a.MIN_START_DT,
    a.MAX_START_DT,
    a.STATUSES AS AUDIT_STATUSES,

    COALESCE(s.STATIC_ROWS, 0) AS STATIC_ROWS,
    s.LAST_APPROVED_AT,
    s.STATIC_STATUSES,

    COALESCE(h.HOME_VIEW_ROWS, 0) AS HOME_VIEW_ROWS,
    h.FIRST_RUN_DATE,
    h.MIN_RUN_DATE,
    h.MAX_RUN_DATE,
    h.HOME_STATUSES,

    CASE
        WHEN m.TABLE_KEY IS NULL THEN 'Missing from INSIGHTS_CORE_INGESTION current metadata'
        WHEN a.TABLE_KEY IS NULL THEN 'Exists in metadata but missing from VW_CORE_INGESTION_SF_LOAD_STATUS'
        WHEN s.TABLE_KEY IS NOT NULL THEN 'Excluded because table already exists in OPS_TEAM_STATIC_INTERFACE_TABLE'
        WHEN h.TABLE_KEY IS NULL THEN 'Present in audit view and not static, but missing from home view - inspect view logic/date calendar'
        ELSE 'Should appear on home page'
    END AS DIAGNOSIS

FROM expected e
LEFT JOIN metadata m ON e.TABLE_KEY = m.TABLE_KEY
LEFT JOIN audit_view a ON e.TABLE_KEY = a.TABLE_KEY
LEFT JOIN static_table s ON e.TABLE_KEY = s.TABLE_KEY
LEFT JOIN home_view h ON e.TABLE_KEY = h.TABLE_KEY
ORDER BY e.TABLE_KEY;
