SELECT
    PSG_TABLE_NAME,
    INTERFACE_NAME,
    PROJECT,
    SOURCE_SYSTEM,
    DATABASE_NAME,
    AUDIT_CURRENT,
    AUDIT_START_DATE,
    AUDIT_END_DATE,
    AUDIT_FILE_PROCESSED_DATE,
    AUDIT_FILE_NAME,
    AUDIT_JOB_GUID
FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION
WHERE PSG_TABLE_NAME = 'ORDERS'
ORDER BY AUDIT_START_DATE DESC, AUDIT_FILE_PROCESSED_DATE DESC;
