WITH recent_metadata AS (
    SELECT
        PSG_TABLE_NAME,
        INTERFACE_NAME,
        PROJECT,
        SOURCE_SYSTEM,
        AUDIT_START_DATE
    FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION
    WHERE AUDIT_CURRENT = TRUE
      AND AUDIT_START_DATE >= DATEADD(day, -60, CURRENT_DATE())
),

audit_names AS (
    SELECT DISTINCT TABLE_NAME
    FROM DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS
)

SELECT
    m.PSG_TABLE_NAME,
    m.INTERFACE_NAME,
    a.TABLE_NAME AS AUDIT_TABLE_NAME,
    m.PROJECT,
    m.SOURCE_SYSTEM,
    m.AUDIT_START_DATE
FROM recent_metadata m
JOIN audit_names a
    ON UPPER(a.TABLE_NAME) LIKE '%' || UPPER(m.PSG_TABLE_NAME) || '%'
    OR UPPER(m.PSG_TABLE_NAME) LIKE '%' || UPPER(a.TABLE_NAME) || '%'
    OR UPPER(a.TABLE_NAME) LIKE '%' || UPPER(m.INTERFACE_NAME) || '%'
    OR UPPER(m.INTERFACE_NAME) LIKE '%' || UPPER(a.TABLE_NAME) || '%'
WHERE UPPER(TRIM(m.PSG_TABLE_NAME)) <> UPPER(TRIM(a.TABLE_NAME))
ORDER BY m.AUDIT_START_DATE DESC, m.PSG_TABLE_NAME, a.TABLE_NAME;
