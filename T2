WITH

PMD_DEDUP AS (
    SELECT
        TRIM(PSG_TABLE_NAME) AS TABLE_NAME,
        TRIM(INTERFACE_NAME) AS INTERFACE_NAME,
        UPPER(TRIM(PSG_TABLE_NAME)) AS TABLE_KEY,
        UPPER(TRIM(INTERFACE_NAME)) AS INTERFACE_KEY
    FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION
    WHERE AUDIT_CURRENT = TRUE
      AND PSG_TABLE_NAME IS NOT NULL
      AND TRIM(PSG_TABLE_NAME) <> ''
    QUALIFY ROW_NUMBER() OVER (
        PARTITION BY UPPER(TRIM(PSG_TABLE_NAME))
        ORDER BY AUDIT_START_DATE DESC, AUDIT_FILE_PROCESSED_DATE DESC
    ) = 1
),

AUDIT_TABLES AS (
    SELECT DISTINCT
        UPPER(TRIM(TABLE_NAME)) AS TABLE_NAME
    FROM DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS
    WHERE TABLE_NAME IS NOT NULL
      AND TRIM(TABLE_NAME) <> ''
),

NEW_TABLES AS (
    SELECT
        M.TABLE_NAME,
        M.INTERFACE_NAME,
        COALESCE(VS1.TABLE_NAME, VS2.TABLE_NAME) AS AUDIT_TABLE_NAME
    FROM PMD_DEDUP M
    LEFT JOIN AUDIT_TABLES VS1
        ON VS1.TABLE_NAME = M.TABLE_KEY
    LEFT JOIN AUDIT_TABLES VS2
        ON VS2.TABLE_NAME = M.INTERFACE_KEY
    WHERE NOT EXISTS (
        SELECT 1
        FROM DB_CORE_PRD.PSG.OPS_TEAM_STATIC_INTERFACE_TABLE SIT
        WHERE UPPER(TRIM(SIT.TABLE_NAME)) = M.TABLE_KEY
           OR UPPER(TRIM(SIT.TABLE_NAME)) = M.INTERFACE_KEY
    )
),

LAST_14_DAYS AS (
    SELECT DAY_DT
    FROM DB_CORE_PRD.PSG.TIME_DAY_DM
    WHERE DAY_DT BETWEEN DATEADD(DAY, -13, CURRENT_DATE()) AND CURRENT_DATE()
),

LATEST_RUN_PER_DAY AS (
    SELECT
        NT.TABLE_NAME,
        CAST(DATE_TRUNC('DAY', VS.START_DT) AS DATE) AS RUN_DATE,
        VS.PROCESS_STATUS,
        ROW_NUMBER() OVER (
            PARTITION BY NT.TABLE_NAME, CAST(DATE_TRUNC('DAY', VS.START_DT) AS DATE)
            ORDER BY VS.START_DT DESC
        ) AS RN
    FROM NEW_TABLES NT
    JOIN DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS VS
        ON UPPER(TRIM(VS.TABLE_NAME)) = NT.AUDIT_TABLE_NAME
    WHERE CAST(VS.START_DT AS DATE) BETWEEN DATEADD(DAY, -13, CURRENT_DATE())
                                        AND CURRENT_DATE()
),

FINAL_PREVIEW AS (
    SELECT
        NT.TABLE_NAME,
        NT.INTERFACE_NAME,
        NT.AUDIT_TABLE_NAME,
        D.DAY_DT AS RUN_DATE,
        CASE
            WHEN LR.PROCESS_STATUS = 'COMPLETE' THEN 'Green'
            WHEN LR.PROCESS_STATUS = 'ERROR' THEN 'Red'
            ELSE 'Yellow'
        END AS RUN_STATUS
    FROM NEW_TABLES NT
    CROSS JOIN LAST_14_DAYS D
    LEFT JOIN LATEST_RUN_PER_DAY LR
        ON LR.TABLE_NAME = NT.TABLE_NAME
       AND LR.RUN_DATE = D.DAY_DT
       AND LR.RN = 1
),

SUMMARY AS (
    SELECT
        TABLE_NAME,
        INTERFACE_NAME,
        AUDIT_TABLE_NAME,
        COUNT(*) AS DAYS_COUNT,
        COUNT_IF(RUN_STATUS = 'Green') AS GREEN_DAYS,
        COUNT_IF(RUN_STATUS = 'Red') AS RED_DAYS,
        COUNT_IF(RUN_STATUS = 'Yellow') AS YELLOW_DAYS
    FROM FINAL_PREVIEW
    GROUP BY TABLE_NAME, INTERFACE_NAME, AUDIT_TABLE_NAME
)

SELECT
    CASE
        WHEN AUDIT_TABLE_NAME IS NULL THEN 'NO_AUDIT_MATCH'
        WHEN YELLOW_DAYS = 14 THEN 'MATCHED_BUT_ALL_YELLOW'
        ELSE 'OK_OR_PARTIAL'
    END AS ISSUE_TYPE,
    COUNT(*) AS TABLE_COUNT
FROM SUMMARY
GROUP BY 1
ORDER BY 1;
