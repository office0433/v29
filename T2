WITH metadata AS (
    SELECT
        UPPER(TRIM(PSG_TABLE_NAME)) AS TABLE_KEY,
        PSG_TABLE_NAME,
        INTERFACE_NAME,
        PROJECT,
        SOURCE_SYSTEM,
        AUDIT_CURRENT,
        AUDIT_START_DATE,
        AUDIT_FILE_PROCESSED_DATE
    FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION
    WHERE AUDIT_CURRENT = TRUE
      AND PSG_TABLE_NAME IS NOT NULL
      AND TRIM(PSG_TABLE_NAME) <> ''
      AND (
            AUDIT_START_DATE >= DATEADD(day, -60, CURRENT_DATE())
         OR CAST(AUDIT_FILE_PROCESSED_DATE AS DATE) >= DATEADD(day, -60, CURRENT_DATE())
      )
),

audit_view AS (
    SELECT
        UPPER(TRIM(TABLE_NAME)) AS TABLE_KEY,
        COUNT(*) AS AUDIT_VIEW_ROWS,
        MIN(START_DT) AS MIN_START_DT,
        MAX(START_DT) AS MAX_START_DT,
        LISTAGG(DISTINCT PROCESS_STATUS, ', ')
            WITHIN GROUP (ORDER BY PROCESS_STATUS) AS AUDIT_STATUSES
    FROM DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS
    GROUP BY 1
),

static_table AS (
    SELECT
        UPPER(TRIM(TABLE_NAME)) AS TABLE_KEY,
        COUNT(*) AS STATIC_ROWS,
        MAX(APPROVED_AT) AS LAST_APPROVED_AT,
        LISTAGG(DISTINCT STATUS, ', ')
            WITHIN GROUP (ORDER BY STATUS) AS STATIC_STATUSES
    FROM DB_CORE_PRD.PSG.OPS_TEAM_STATIC_INTERFACE_TABLE
    GROUP BY 1
),

home_view AS (
    SELECT
        UPPER(TRIM(TABLE_NAME)) AS TABLE_KEY,
        COUNT(*) AS HOME_VIEW_ROWS,
        MIN(FIRST_RUN_DATE) AS FIRST_RUN_DATE,
        MIN(RUN_DATE) AS MIN_RUN_DATE,
        MAX(RUN_DATE) AS MAX_RUN_DATE,
        LISTAGG(DISTINCT RUN_STATUS, ', ')
            WITHIN GROUP (ORDER BY RUN_STATUS) AS HOME_STATUSES
    FROM DB_CORE_PRD.PSG.VW_NEW_INGESTION_STATUS_LAST_14_DAYS
    GROUP BY 1
)

SELECT
    m.PSG_TABLE_NAME,
    m.INTERFACE_NAME,
    m.PROJECT,
    m.SOURCE_SYSTEM,
    m.AUDIT_START_DATE,
    m.AUDIT_FILE_PROCESSED_DATE,

    COALESCE(a.AUDIT_VIEW_ROWS, 0) AS AUDIT_VIEW_ROWS,
    a.MIN_START_DT,
    a.MAX_START_DT,
    a.AUDIT_STATUSES,

    COALESCE(s.STATIC_ROWS, 0) AS STATIC_ROWS,
    s.LAST_APPROVED_AT,
    s.STATIC_STATUSES,

    COALESCE(h.HOME_VIEW_ROWS, 0) AS HOME_VIEW_ROWS,
    h.FIRST_RUN_DATE,
    h.MIN_RUN_DATE,
    h.MAX_RUN_DATE,
    h.HOME_STATUSES,

    CASE
        WHEN h.TABLE_KEY IS NOT NULL THEN 'Already visible in Streamlit home view'
        WHEN a.TABLE_KEY IS NULL THEN 'In metadata but missing from VW_CORE_INGESTION_SF_LOAD_STATUS'
        WHEN s.TABLE_KEY IS NOT NULL THEN 'Excluded because already exists in OPS_TEAM_STATIC_INTERFACE_TABLE'
        ELSE 'Should appear - inspect home view/calendar logic'
    END AS DIAGNOSIS

FROM metadata m
LEFT JOIN audit_view a ON m.TABLE_KEY = a.TABLE_KEY
LEFT JOIN static_table s ON m.TABLE_KEY = s.TABLE_KEY
LEFT JOIN home_view h ON m.TABLE_KEY = h.TABLE_KEY
WHERE h.TABLE_KEY IS NULL
ORDER BY
    m.AUDIT_START_DATE DESC,
    m.AUDIT_FILE_PROCESSED_DATE DESC,
    m.PSG_TABLE_NAME;
