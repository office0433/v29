SELECT
    m.PSG_TABLE_NAME,
    m.INTERFACE_NAME,
    v.TABLE_NAME AS AUDIT_TABLE_NAME
FROM DB_CORE_PRD.PMD.INSIGHTS_CORE_INGESTION m
LEFT JOIN DB_CORE_PRD.PSG.VW_CORE_INGESTION_SF_LOAD_STATUS v
    ON UPPER(TRIM(v.TABLE_NAME)) = UPPER(TRIM(m.PSG_TABLE_NAME))
WHERE m.AUDIT_CURRENT = TRUE
  AND m.AUDIT_START_DATE >= DATEADD(day, -60, CURRENT_DATE())
  AND v.TABLE_NAME IS NULL
ORDER BY m.AUDIT_START_DATE DESC;
